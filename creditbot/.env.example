APP_NAME=CrediBot
APP_ENV=development
APP_DEBUG=true
APP_PUBLIC_URL=https://your-public-domain.com

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_VALIDATE_SIGNATURE=false

DEFAULT_COUNTRY_CODE=593
ADMIN_DASHBOARD_PASSWORD=change-this-password

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=500
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_ITERATIONS=3
LLM_PROVIDER=openai
ENABLE_GPT_AGENT=false

# Evolution API (v3.1 — bloque D)
WHATSAPP_PROVIDER=twilio
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=credibot-pruebas
EVOLUTION_WEBHOOK_SECRET=
EVOLUTION_TIMEOUT_SECONDS=15
EVOLUTION_MAX_RETRIES=2

# Dashboard / simulador remoto
CREDIBOT_API_URL=http://127.0.0.1:8001

META_VERIFY_TOKEN=
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_APP_SECRET=
WHATSAPP_PROVIDER=twilio

REDIS_URL=
